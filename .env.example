# ============================================
# Codex AI v2 — Environment Variables
# Copy to .env and fill in your values
# ============================================

# === Telegram (REQUIRED) ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_ID=-100xxxxxxxxxx
TELEGRAM_ADMIN_USER_ID=your_user_id_here

# === OpenFang — Agent execution engine ===
OPENFANG_URL=http://127.0.0.1:4200
OPENFANG_API_KEY=

# === CLIProxyAPI (configured as OpenFang provider) ===
CLIPROXY_URL=http://127.0.0.1:8317
CLIPROXY_API_KEY=openfang-key-2026

# === Paperclip — Project management ===
PAPERCLIP_URL=http://127.0.0.1:3100

# === Default Models (tuỳ chỉnh cho từng agent) ===
DEFAULT_MODEL_CTO=o3
DEFAULT_MODEL_ENGINEER=gpt-4o
DEFAULT_MODEL_QA=gpt-4o-mini
DEFAULT_MODEL_CRITIC=gpt-4o

# === Debate Settings ===
DEBATE_MAX_ROUNDS=6
DEBATE_COOLDOWN_SEC=30
